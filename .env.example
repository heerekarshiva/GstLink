# ════════════════════════════════════════════════════
# GSTLink Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ════════════════════════════════════════════════════

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-before-deploying

# Database (Railway auto-sets this for Postgres)
DATABASE_URL=sqlite:///gstlink.db

# Your deployed app URL — used for QR codes, OG tags, sitemap
# Example: https://gstlink.in  or  https://yourapp.railway.app
BASE_URL=https://your-domain.com

# Groq API Key — free at https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe — get from https://dashboard.stripe.com/apikeys
# Use sk_test_ / pk_test_ for testing, sk_live_ / pk_live_ for production
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxxxxx

# Mail (for password reset & email verification)
# Use Gmail App Password: https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@gstlink.in

# Redis (for persistent rate limiting across workers/deploys)
# Add Redis plugin on Railway → it auto-sets REDIS_URL
REDIS_URL=redis://localhost:6379/0
